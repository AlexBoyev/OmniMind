# =============================================================================
# OmniMind — Environment Configuration Template
# Copy this file to .env and fill in values before running the stack.
# NEVER commit .env to version control.
# =============================================================================

# =============================================================================
# GENERAL
# =============================================================================
ENVIRONMENT=development
APP_NAME=OmniMind
APP_VERSION=0.1.0
LOG_LEVEL=INFO
TIMEZONE=UTC

# =============================================================================
# FRONTEND (Vite build-time variables — must start with VITE_)
# =============================================================================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=OmniMind
VITE_ENABLE_JARVIS=true

# =============================================================================
# POSTGRESQL
# =============================================================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=omnimind
POSTGRES_USER=omnimind
POSTGRES_PASSWORD=changeme_postgres_password
DATABASE_URL=postgresql+asyncpg://omnimind:changeme_postgres_password@postgres:5432/omnimind

# =============================================================================
# REDIS
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=changeme_redis_password
REDIS_URL=redis://:changeme_redis_password@redis:6379/0

# =============================================================================
# JWT AUTHENTICATION
# =============================================================================
SECRET_KEY=REPLACE_WITH_OUTPUT_OF_openssl_rand_-hex_64
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# =============================================================================
# SECURITY
# =============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_JARVIS=20/minute
BCRYPT_ROUNDS=12
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_HTTPONLY=true

# =============================================================================
# SEED USERS (created on first migration + seed)
# =============================================================================
SEED_ADMIN_EMAIL=admin@omnimind.local
SEED_ADMIN_PASSWORD=Admin1234!
SEED_ADMIN_FULL_NAME=Admin User

SEED_USER_EMAIL=user@omnimind.local
SEED_USER_PASSWORD=User1234!
SEED_USER_FULL_NAME=Regular User

# =============================================================================
# PGADMIN
# =============================================================================
PGADMIN_EMAIL=admin@omnimind.local
PGADMIN_PASSWORD=pgadmin_password

# =============================================================================
# RESERVED — Phase 7–8 (fill in when reaching those phases)
# =============================================================================

# Claude AI / Anthropic
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
CLAUDE_MODEL=claude-sonnet-4-6

# Telegram Bot
TELEGRAM_BOT_TOKEN=REPLACE_ME

# Twilio (WhatsApp)
TWILIO_ACCOUNT_SID=REPLACE_ME
TWILIO_AUTH_TOKEN=REPLACE_ME
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# GitHub Container Registry
GHCR_REGISTRY=ghcr.io
GHCR_USERNAME=REPLACE_ME
GHCR_TOKEN=REPLACE_ME
GHCR_IMAGE_BACKEND=ghcr.io/REPLACE_ME/omnimind-backend
GHCR_IMAGE_FRONTEND=ghcr.io/REPLACE_ME/omnimind-frontend

# Jenkins
JENKINS_URL=http://jenkins.omnimind.local
JENKINS_USER=admin
JENKINS_TOKEN=REPLACE_ME

# ArgoCD
ARGOCD_SERVER=argocd.omnimind.local
ARGOCD_USER=admin
ARGOCD_PASSWORD=REPLACE_ME

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=REPLACE_ME
GRAFANA_SECRET_KEY=REPLACE_ME
